# Slack
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_SIGNING_SECRET=your-signing-secret
SLACK_APP_TOKEN=xapp-your-app-token

# Atlas API
ATLAS_API_URL=https://sandbox.atriptech.com/api
ATLAS_CLIENT_ID=your-client-id
ATLAS_CLIENT_SECRET=your-client-secret

# FluxA Wallet
FLUXA_WALLET_API_KEY=your-fluxa-api-key
FLUXA_WALLET_ADDRESS=0x...

# Reimbursement API
REIMBURSEMENT_API_URL=https://reimburse.fluxapay.xyz/api
REIMBURSEMENT_API_KEY=your-reimburse-api-key

# Database (optional - for temp orders)
DATABASE_URL=postgresql://user:pass@localhost:5432/flight_booking

# Server
PORT=3000
NODE_ENV=development
